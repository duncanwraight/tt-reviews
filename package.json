{
  "name": "tt-reviews-new",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "deploy": "npm run build && wrangler deploy",
    "dev": "react-router dev",
    "dev:wrangler": "wrangler dev --env dev",
    "postinstall": "npm run cf-typegen",
    "preview": "npm run build && vite preview",
    "typecheck": "npm run cf-typegen && react-router typegen && tsc -b",
    "check": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:discord": "vitest run app/lib/__tests__/discord.test.ts",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test --config=playwright.smoke.config.ts",
    "lint": "eslint .",
    "logs": "wrangler tail --format=pretty",
    "logs:errors": "wrangler tail --format=json --status error"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml,css}": "prettier --write",
    "*.{ts,tsx}": "eslint --fix"
  },
  "dependencies": {
    "@react-router/fs-routes": "^7.14.2",
    "@react-router/node": "^7.14.2",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.48.1",
    "@types/sanitize-html": "^2.16.1",
    "isbot": "^5.1.27",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.14.2",
    "sanitize-html": "^2.17.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.12",
    "@playwright/test": "^1.59.1",
    "@react-router/dev": "^7.14.2",
    "@tailwindcss/vite": "^4.1.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "dotenv": "^16.4.7",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.2",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.3.3",
    "vite-plugin-devtools-json": "^0.2.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.8",
    "wrangler": "^4.19.2"
  }
}
