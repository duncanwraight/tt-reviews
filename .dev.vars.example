# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key  
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Cloudflare R2 Configuration
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=your_bucket_name

# Site Configuration
SITE_URL=https://tt-reviews.local

# CSRF signing secret. Must be at least 16 chars. Generate one with:
#   openssl rand -hex 32
# Prod must set this via `wrangler secret put SESSION_SECRET`.
SESSION_SECRET=replace-with-a-long-random-value

# Discord Configuration (optional for local dev, required for notifications)
# IMPORTANT: use a *dev-only* Discord application, not the prod one. The
# Interactions Endpoint URL is registered per-application, so reusing prod
# credentials means dev button clicks land on prod. See docs/DISCORD.md.
DISCORD_BOT_TOKEN=your_dev_discord_bot_token
DISCORD_CHANNEL_ID=your_dev_discord_channel_id
DISCORD_GUILD_ID=your_dev_discord_guild_id
# DISCORD_PUBLIC_KEY accepts a CSV of Ed25519 public keys (Discord
# verifies against any). Set this to the dev Discord app's real key
# so real button clicks verify against the dev server. The well-known
# e2e test public key (from e2e/utils/discord.ts) is auto-accepted
# when ENVIRONMENT=development, so you do NOT need to list it here for
# `npm run test:e2e` to pass — explicitly listing it still works.
# The test key MUST NOT appear in production env.
DISCORD_PUBLIC_KEY=your_dev_discord_public_key
# DISCORD_ALLOWED_ROLES restricts who can click moderation buttons.
# In dev, the e2e test role string is auto-allowed in addition to
# whatever's listed here, so Playwright Discord specs pass without
# appending it. In prod, only the listed role IDs apply.
DISCORD_ALLOWED_ROLES=role_id_1,role_id_2

# Auto Admin Promotion
# Comma-separated list of email addresses that should be automatically promoted to admin
# These users will become admin when they sign up or sign in
AUTO_ADMIN_EMAILS=admin@yourcompany.com,moderator@yourcompany.com